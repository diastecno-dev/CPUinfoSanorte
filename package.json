{
  "name": "cpuinfosanorte",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.diastecno.cpuinfo",
    "productName": "CPU Info Sanorte",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "portable": {
      "requestExecutionLevel": "admin"
    },
    "npmRebuild": false,
    "files": [
      "main.js",
      "package.json",
      "frontend/dist/**/*"
    ],
    "npmRebuild": false,
    "asar": true
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "systeminformation": "^5.31.3"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}